<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_user_header">

            <ImageView
                android:id="@+id/btnBack_UserProfile"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_margin="16dp"
                android:padding="6dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@drawable/bg_circle_white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgUser"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:padding="3dp"
                android:src="@drawable/ic_profile_placeholder"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.3"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="3dp" />

            <TextView
                android:id="@+id/userName_Profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tên Du Sơ"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/imgUser" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account Settings"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:textColor="#888"/>

            <RelativeLayout
                android:id="@+id/layoutEditUser"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="15dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="10dp">
                <ImageView android:id="@+id/iconEdit" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_edit" android:layout_centerVertical="true" app:tint="#555"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sửa hồ sơ" android:layout_toEndOf="@id/iconEdit" android:layout_marginStart="15dp" android:layout_centerVertical="true" android:textColor="#333"/>
            </RelativeLayout>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#27AE60"
                android:text="Đăng xuất"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>